# Firebase Client (public — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=soul-foundry-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=soul-foundry-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=soul-foundry-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=926162528544
NEXT_PUBLIC_FIREBASE_APP_ID=1:926162528544:web:0f11b5ca9033d574db0f45

# Razorpay (public key only — safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxx

# Razorpay Plan IDs (from Firebase Secret Manager — copy here for local dev)
RAZORPAY_PLAN_STARTER_ID=plan_xxxx
RAZORPAY_PLAN_CORE_ID=plan_xxxx
RAZORPAY_PLAN_GROWTH_ID=plan_xxxx
RAZORPAY_PLAN_STUDIO_ID=plan_xxxx

# Firebase Admin (server-side only — NEVER prefix with NEXT_PUBLIC_)
FIREBASE_ADMIN_PROJECT_ID=soul-foundry-app
FIREBASE_ADMIN_CLIENT_EMAIL=your_service_account@soul-foundry-app.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# App
NEXT_PUBLIC_APP_URL=https://roovero.com
